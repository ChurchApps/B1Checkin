{
  "expo": {
    "name": "B1Checkin",
    "slug": "b1-checkin",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "b1checkin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "churchapps",
    "extra": {
      "eas": {
        "projectId": "669d90d6-0e0e-4b06-9e83-8a6d24dd7d41"
      },
      "router": {}
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "church.b1.checkin",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "church.b1.checkin",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "B1 Checkin needs local network access to find and communicate with Brother label printers on your WiFi network."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./modules/printer-helper/app.plugin.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/images/logo1.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-firebase/app",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "b1-checkin",
          "organization": "churchapps"
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/669d90d6-0e0e-4b06-9e83-8a6d24dd7d41"
    },
    "runtimeVersion": "1.1.0"
  }
}
