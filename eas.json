{
  "cli": {
    "version": ">= 14.5.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": false,
      "channel": "production",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "ios": {
        "image": "latest"
      }
    },
    "amazon": {
      "autoIncrement": false,
      "environment": "production",
      "channel": "production",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "android": {
        "distribution": "internal",
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "GooglePlay": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json"
      }
    },
    "Amazon": {
      "android": {
      }
    },
    "AppStore": {
      "ios": {}
    }
  }
}